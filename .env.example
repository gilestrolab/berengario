# =============================================================================
# Berengario — Single-Tenant Docker Deployment
# =============================================================================
# Copy this file to .env and fill in your values.
# For multi-tenant deployments, use .env.mt.example instead.
#
# IMPORTANT: Never commit .env — it contains secrets. It is already in .gitignore.
# =============================================================================

# -----------------------------------------------------------------------------
# Instance Configuration
# -----------------------------------------------------------------------------
# These values personalize the assistant's identity and behavior.
INSTANCE_NAME=Berengario
INSTANCE_DESCRIPTION=AI-powered Knowledge Base Assistant
ORGANIZATION=Your Organization
WEB_BASE_URL=https://your-domain.com

# -----------------------------------------------------------------------------
# LLM & Embedding API
# -----------------------------------------------------------------------------
# Naga.ac (OpenAI-compatible, cheaper) — or use OpenAI / any compatible provider.
OPENAI_API_KEY=your-api-key-here
OPENAI_API_BASE=https://api.naga.ac/v1
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# LLM for queries, enhancement, and optimization.
OPENROUTER_API_KEY=your-api-key-here
OPENROUTER_API_BASE=https://api.naga.ac/v1
OPENROUTER_MODEL=claude-sonnet-4.6
# Fallback model used when primary fails (400, 5xx, timeout). Default: kimi-k2.5
# OPENROUTER_FALLBACK_MODEL=kimi-k2.5

# -----------------------------------------------------------------------------
# Email — Inbox (IMAP)
# -----------------------------------------------------------------------------
IMAP_SERVER=imap.your-provider.com
IMAP_PORT=993
IMAP_USER=ask@yourdomain.com
IMAP_PASSWORD=your-password-here
IMAP_USE_SSL=true

# -----------------------------------------------------------------------------
# Email — Sending (SMTP)
# -----------------------------------------------------------------------------
SMTP_SERVER=smtp.your-provider.com
SMTP_PORT=587
SMTP_USER=ask@yourdomain.com
SMTP_PASSWORD=your-password-here
SMTP_USE_TLS=true

# -----------------------------------------------------------------------------
# Email Processing
# -----------------------------------------------------------------------------
EMAIL_CHECK_INTERVAL=300
EMAIL_TARGET_ADDRESS=ask@yourdomain.com
EMAIL_DISPLAY_NAME=Berengario
EMAIL_TEMP_DIR=data/temp_attachments
MAX_ATTACHMENT_SIZE=10485760

# Response format: text, markdown, or html (styled)
EMAIL_RESPONSE_FORMAT=html
# Custom footer (optional) — copy data/config/email_footer.txt.example and customize
# EMAIL_CUSTOM_FOOTER_FILE=data/config/email_footer.txt

# Forwarded email detection
FORWARD_TO_KB_ENABLED=true
# Case-insensitive prefixes (e.g. add "i" for Italian, "rv" for Spanish)
FORWARD_SUBJECT_PREFIXES=fw,fwd

# Dedicated teach address (optional) — emails To/CC this address are always KB content
# EMAIL_TEACH_ADDRESS=teach@yourdomain.com

# Welcome emails for newly added team members
WELCOME_EMAIL_ENABLED=true

# -----------------------------------------------------------------------------
# Database (MariaDB in Docker)
# -----------------------------------------------------------------------------
# Note: User/team management is handled via the admin panel (Team Members section).
DB_HOST=mariadb
DB_PORT=3306
DB_NAME=berengario
DB_USER=berengario
DB_PASSWORD=your-db-password-here
# DB_POOL_SIZE=5
# DB_POOL_RECYCLE=3600

# Root password for the MariaDB container (not used by the app)
MYSQL_ROOT_PASSWORD=your-root-password-here

# -----------------------------------------------------------------------------
# Document Processing & Knowledge Base
# -----------------------------------------------------------------------------
DOCUMENTS_PATH=data/kb/documents
CHROMA_DB_PATH=data/chroma_db
KB_DOCUMENTS_PATH=data/kb/documents
KB_EMAILS_PATH=data/kb/emails

# -----------------------------------------------------------------------------
# RAG Configuration
# -----------------------------------------------------------------------------
CHUNK_SIZE=1024
CHUNK_OVERLAP=200
TOP_K_RETRIEVAL=5
SIMILARITY_THRESHOLD=0.7

# Custom system prompt additions (optional)
# RAG_CUSTOM_PROMPT_FILE=data/config/custom_prompt.txt

# -----------------------------------------------------------------------------
# Reranking (Cohere API — state-of-the-art reranking, ~$0.002/query)
# -----------------------------------------------------------------------------
RERANKING_ENABLED=true
COHERE_API_KEY=your-cohere-api-key-here
RERANKING_MODEL=rerank-v3.5
# RERANKING_TOP_N=5  # Override reranker output count (defaults to TOP_K_RETRIEVAL)

# -----------------------------------------------------------------------------
# Hybrid Search (BM25 keyword search + vector semantic search)
# -----------------------------------------------------------------------------
HYBRID_SEARCH_ENABLED=true

# -----------------------------------------------------------------------------
# Contextual Enrichment (prepend document context to each chunk)
# -----------------------------------------------------------------------------
CONTEXTUAL_ENRICHMENT_ENABLED=true

# -----------------------------------------------------------------------------
# Query Optimization
# -----------------------------------------------------------------------------
QUERY_OPTIMIZATION_ENABLED=true
# QUERY_OPTIMIZATION_MODEL=claude-sonnet-4.6
QUERY_OPTIMIZATION_MAX_TOKENS=500
QUERY_OPTIMIZATION_TEMPERATURE=0.3
QUERY_OPTIMIZATION_TIMEOUT=10

# -----------------------------------------------------------------------------
# Document Enhancement (for CSV/Excel)
# -----------------------------------------------------------------------------
DOC_ENHANCEMENT_ENABLED=true
# DOC_ENHANCEMENT_MODEL=claude-sonnet-4.6
DOC_ENHANCEMENT_MAX_TOKENS=4000
DOC_ENHANCEMENT_TYPES=narrative,qa

# -----------------------------------------------------------------------------
# Web API
# -----------------------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=false
CORS_ORIGINS=["http://localhost:8090"]

# Session timeout for authenticated users (seconds, default 24h)
WEB_SESSION_TIMEOUT=86400

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
LOG_FILE=data/logs/berengario.log

# -----------------------------------------------------------------------------
# Paddle Billing (subscription management)
# -----------------------------------------------------------------------------
# Get these from your Paddle dashboard: https://vendors.paddle.com/
PADDLE_API_KEY=
PADDLE_ENVIRONMENT=sandbox
PADDLE_CLIENT_TOKEN=
PADDLE_WEBHOOK_SECRET=
PADDLE_PRICE_ID_LITE=
PADDLE_PRICE_ID_TEAM=
PADDLE_PRICE_ID_DEPARTMENT=

# Trial duration for new tenants (days, default 90 = 3 months)
TRIAL_DURATION_DAYS=90

# -----------------------------------------------------------------------------
# Development
# -----------------------------------------------------------------------------
DEBUG=false
# SECURITY WARNING: Disables OTP email verification. NEVER enable in production.
DISABLE_OTP_FOR_DEV=false
