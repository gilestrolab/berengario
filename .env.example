# Instance Configuration (customize for each deployment)
# These values personalize the AI assistant's behavior and responses
INSTANCE_NAME=DoLS-GPT
INSTANCE_DESCRIPTION=AI assistant for the Department of Life Sciences
ORGANIZATION=Imperial College London
WEB_BASE_URL=http://localhost:8000

# Naga.ac Configuration (OpenAI-compatible API - cheaper than OpenRouter)
# Get your API key from https://naga.ac
OPENAI_API_KEY=ng-your-naga-key-here
OPENAI_API_BASE=https://api.naga.ac/v1
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# LLM Configuration (uses Naga.ac)
OPENROUTER_API_KEY=ng-your-naga-key-here
OPENROUTER_API_BASE=https://api.naga.ac/v1
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet

# Email Configuration - Inbox (IMAP)
IMAP_SERVER=outlook.office365.com
IMAP_PORT=993
IMAP_USER=dolsbot@ic.ac.uk
IMAP_PASSWORD=your-password-here
IMAP_USE_SSL=true

# Email Configuration - Sending (SMTP)
SMTP_SERVER=smtp.office365.com
SMTP_PORT=587
SMTP_USER=dolsbot@ic.ac.uk
SMTP_PASSWORD=your-password-here
SMTP_USE_TLS=true

# Email Processing
EMAIL_CHECK_INTERVAL=300
EMAIL_TARGET_ADDRESS=dols.gpt@imperial.ac.uk
EMAIL_DISPLAY_NAME=DoLS GPT assistant
EMAIL_TEMP_DIR=./data/temp_attachments
MAX_ATTACHMENT_SIZE=10485760

# Email Response Customization
# Format for email responses: text (plain), markdown (plain text with markdown), or html (styled)
EMAIL_RESPONSE_FORMAT=html
# Custom email footer to replace default (optional)
# Copy data/config/email_footer.txt.example and customize
# EMAIL_CUSTOM_FOOTER_FILE=data/config/email_footer.txt

# Forwarded Email Detection
# Should forwarded emails (To: bot) be treated as KB content instead of queries?
FORWARD_TO_KB_ENABLED=true
# Case-insensitive subject prefixes that indicate forwarded emails
# Customize for your language (e.g., "tr,i" for Italian "I:", "rv" for Spanish "RV:")
FORWARD_SUBJECT_PREFIXES=fw,fwd

# Email Whitelists (Security - Dual lists for teach vs query permissions)
# Note: Users can be in one list, both lists, or neither

# Teaching Whitelist (who can add content to KB via CC/BCC/forwarding)
# Option 1: Inline list (comma-separated)
EMAIL_TEACH_WHITELIST=@imperial.ac.uk,@ic.ac.uk
# Option 2: File-based list (one entry per line) - RECOMMENDED
EMAIL_TEACH_WHITELIST_FILE=data/config/allowed_teachers.txt
# Enable/disable teaching whitelist
EMAIL_TEACH_WHITELIST_ENABLED=true

# Query Whitelist (who can query KB and receive RAG replies)
# Option 1: Inline list (comma-separated)
EMAIL_QUERY_WHITELIST=@imperial.ac.uk,@ic.ac.uk
# Option 2: File-based list (one entry per line) - RECOMMENDED
EMAIL_QUERY_WHITELIST_FILE=data/config/allowed_queriers.txt
# Enable/disable query whitelist
EMAIL_QUERY_WHITELIST_ENABLED=true

# Admin Whitelist (who has full admin access to web interface)
# WARNING: Admin users can:
# - View and modify all whitelists (queriers, teachers, admins)
# - View all KB documents and their metadata
# - Delete documents from KB (files are archived, not permanently deleted)
# - All admin actions are logged to data/logs/admin_audit.log
#
# SECURITY: Only grant admin access to trusted users
# Option 1: Inline list (comma-separated)
EMAIL_ADMIN_WHITELIST=admin@imperial.ac.uk
# Option 2: File-based list (one entry per line) - RECOMMENDED
EMAIL_ADMIN_WHITELIST_FILE=data/config/allowed_admins.txt
# Enable/disable admin whitelist
EMAIL_ADMIN_WHITELIST_ENABLED=true

# Database Configuration (Message Tracking)
# Options: sqlite (default, simple) or mariadb (production/docker)
DB_TYPE=sqlite

# SQLite Configuration (when DB_TYPE=sqlite)
SQLITE_DB_PATH=./data/message_tracker.db

# MariaDB Configuration (when DB_TYPE=mariadb)
# Uncomment and configure if using MariaDB in Docker/production
# DB_HOST=mariadb
# DB_PORT=3306
# DB_NAME=raginbox
# DB_USER=raginbox
# DB_PASSWORD=your_secure_password
# DB_POOL_SIZE=5
# DB_POOL_RECYCLE=3600

# Document Processing (relative paths recommended for Docker compatibility)
# DOCUMENTS_PATH is watched by FileWatcher for automatically processing new files
DOCUMENTS_PATH=data/kb/documents
CHROMA_DB_PATH=data/chroma_db

# Knowledge Base Structure
KB_DOCUMENTS_PATH=data/kb/documents
KB_EMAILS_PATH=data/kb/emails

# RAG Configuration
CHUNK_SIZE=1024
CHUNK_OVERLAP=200
TOP_K_RETRIEVAL=5
SIMILARITY_THRESHOLD=0.7

# RAG Customization
# Custom system prompt additions to append to base prompt (optional)
# Copy data/config/custom_prompt.txt.example and customize
# RAG_CUSTOM_PROMPT_FILE=data/config/custom_prompt.txt

# Document Enhancement Configuration
# Enable LLM-based enhancement for structured data (CSV/Excel) to improve RAG retrieval
DOC_ENHANCEMENT_ENABLED=true
# Model to use for enhancement (default: same as OPENROUTER_MODEL)
# DOC_ENHANCEMENT_MODEL=anthropic/claude-3.5-sonnet
# Maximum tokens to use for enhancement (higher = more detailed but more expensive)
DOC_ENHANCEMENT_MAX_TOKENS=4000
# Types of enhancement to apply: narrative (converts tables to narrative), qa (generates Q&A pairs)
# Both types improve semantic search for dry documents
DOC_ENHANCEMENT_TYPES=narrative,qa

# Web API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=false
CORS_ORIGINS=["http://localhost:8000"]

# Web Authentication
# Session timeout for authenticated users (in seconds)
# Default: 86400 (24 hours)
WEB_SESSION_TIMEOUT=86400

# Logging
LOG_LEVEL=INFO
LOG_FILE=data/logs/dols_gpt.log

# Development
DEBUG=false

# SECURITY WARNING: Only for development! Disables OTP email verification.
# When enabled, any user in the query whitelist can login without receiving/entering an OTP code.
# DO NOT enable in production environments!
# Default: false (OTP authentication enabled)
DISABLE_OTP_FOR_DEV=false
