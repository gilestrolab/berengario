# =============================================================================
# Berengario — Multi-Tenant Docker Deployment
# =============================================================================
# Copy this file to .env and fill in your values.
# This configuration enables multi-tenant mode with isolated data per tenant.
#
# For single-tenant deployments, use .env.example instead.
#
# IMPORTANT: Never commit .env — it contains secrets. It is already in .gitignore.
# =============================================================================

# In MT mode, instance name/description/organization are per-tenant
# (stored in the database, managed via the platform admin panel).
WEB_BASE_URL=http://localhost:8090

# -----------------------------------------------------------------------------
# LLM & Embedding API
# -----------------------------------------------------------------------------
OPENAI_API_KEY=your-api-key-here
OPENAI_API_BASE=https://api.naga.ac/v1
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

OPENROUTER_API_KEY=your-api-key-here
OPENROUTER_API_BASE=https://api.naga.ac/v1
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet

# -----------------------------------------------------------------------------
# Email — Inbox (IMAP)
# -----------------------------------------------------------------------------
IMAP_SERVER=imap.your-provider.com
IMAP_PORT=993
IMAP_USER=ask@yourdomain.com
IMAP_PASSWORD=your-password-here
IMAP_USE_SSL=true

# -----------------------------------------------------------------------------
# Email — Sending (SMTP)
# -----------------------------------------------------------------------------
SMTP_SERVER=smtp.your-provider.com
SMTP_PORT=587
SMTP_USER=ask@yourdomain.com
SMTP_PASSWORD=your-password-here
SMTP_USE_TLS=true

# -----------------------------------------------------------------------------
# Email Processing
# -----------------------------------------------------------------------------
EMAIL_CHECK_INTERVAL=300
EMAIL_TARGET_ADDRESS=ask@yourdomain.com
EMAIL_DISPLAY_NAME=Berengario
EMAIL_TEMP_DIR=data/temp_attachments
MAX_ATTACHMENT_SIZE=10485760

EMAIL_RESPONSE_FORMAT=html
# EMAIL_CUSTOM_FOOTER_FILE=data/config/email_footer.txt

FORWARD_TO_KB_ENABLED=true
FORWARD_SUBJECT_PREFIXES=fw,fwd
# EMAIL_TEACH_ADDRESS=teach@yourdomain.com

WELCOME_EMAIL_ENABLED=true

# NOTE: In multi-tenant mode, access control is managed per-tenant via the
# TenantUser table (admin panel), NOT via file-based whitelists.
# The whitelist settings below are ignored when MULTI_TENANT=true.

# -----------------------------------------------------------------------------
# Database (MariaDB in Docker)
# -----------------------------------------------------------------------------
DB_TYPE=mariadb
DB_HOST=mariadb
DB_PORT=3306
DB_NAME=berengario
DB_USER=berengario
DB_PASSWORD=your-db-password-here
# DB_POOL_SIZE=5
# DB_POOL_RECYCLE=3600

# Root password for the MariaDB container (not used by the app)
MYSQL_ROOT_PASSWORD=your-root-password-here

# -----------------------------------------------------------------------------
# Document Processing & Knowledge Base
# -----------------------------------------------------------------------------
DOCUMENTS_PATH=data/kb/documents
CHROMA_DB_PATH=data/chroma_db
KB_DOCUMENTS_PATH=data/kb/documents
KB_EMAILS_PATH=data/kb/emails

# -----------------------------------------------------------------------------
# RAG Configuration
# -----------------------------------------------------------------------------
CHUNK_SIZE=1024
CHUNK_OVERLAP=200
TOP_K_RETRIEVAL=5
SIMILARITY_THRESHOLD=0.7
# RAG_CUSTOM_PROMPT_FILE=data/config/custom_prompt.txt

# -----------------------------------------------------------------------------
# Query Optimization
# -----------------------------------------------------------------------------
QUERY_OPTIMIZATION_ENABLED=true
QUERY_OPTIMIZATION_MAX_TOKENS=500
QUERY_OPTIMIZATION_TEMPERATURE=0.3
QUERY_OPTIMIZATION_TIMEOUT=10

# -----------------------------------------------------------------------------
# Document Enhancement (for CSV/Excel)
# -----------------------------------------------------------------------------
DOC_ENHANCEMENT_ENABLED=true
DOC_ENHANCEMENT_MAX_TOKENS=4000
DOC_ENHANCEMENT_TYPES=narrative,qa

# -----------------------------------------------------------------------------
# Web API
# -----------------------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=false
CORS_ORIGINS=["http://localhost:8090"]
WEB_SESSION_TIMEOUT=86400

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
LOG_FILE=data/logs/berengario.log

# -----------------------------------------------------------------------------
# Development
# -----------------------------------------------------------------------------
DEBUG=false
DISABLE_OTP_FOR_DEV=false

# =============================================================================
# Multi-Tenancy Configuration
# =============================================================================

MULTI_TENANT=true

# Platform domain (used for tenant email addresses and links)
PLATFORM_DOMAIN=berengar.io
PLATFORM_BASE_URL=https://berengar.io

# -----------------------------------------------------------------------------
# Platform Database (shared across all tenants)
# -----------------------------------------------------------------------------
PLATFORM_DB_HOST=mariadb
PLATFORM_DB_PORT=3306
PLATFORM_DB_NAME=berengario_platform
PLATFORM_DB_USER=berengario
PLATFORM_DB_PASSWORD=your-db-password-here

# -----------------------------------------------------------------------------
# Platform Admin Panel
# -----------------------------------------------------------------------------
# Comma-separated emails allowed to access the platform admin panel
PLATFORM_ADMIN_EMAILS=admin@example.com

# -----------------------------------------------------------------------------
# Storage Backend
# -----------------------------------------------------------------------------
# "local" stores files under data/tenants/{slug}/
# "s3" stores files in per-tenant S3/MinIO buckets
STORAGE_BACKEND=s3

# S3 / MinIO configuration (when STORAGE_BACKEND=s3)
S3_ENDPOINT_URL=http://minio:9000
S3_ACCESS_KEY=your-minio-access-key-here
S3_SECRET_KEY=your-minio-secret-key-here
S3_REGION=us-east-1
S3_BUCKET_PREFIX=berengario-tenant-

# MinIO container credentials (must match S3_ACCESS_KEY / S3_SECRET_KEY)
MINIO_ROOT_USER=your-minio-access-key-here
MINIO_ROOT_PASSWORD=your-minio-secret-key-here

# -----------------------------------------------------------------------------
# Per-Tenant Encryption (optional but recommended)
# -----------------------------------------------------------------------------
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
MASTER_ENCRYPTION_KEY=your-generated-fernet-key-here

# Tenant database connection pool tuning
TENANT_DB_POOL_SIZE=3
TENANT_DB_MAX_CACHED=50
